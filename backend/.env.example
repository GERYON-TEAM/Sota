# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sota

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-use-secrets-token-hex-32

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
